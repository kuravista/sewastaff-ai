# SewaStaff AI Backend

# PostgreSQL
POSTGRES_USER=sewastaff
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sewastaff

# Database URL
DATABASE_URL=postgresql+asyncpg://sewastaff:changeme@postgres:5432/sewastaff

# Redis
REDIS_URL=redis://redis:6379/0

# WAHA (already running on host port 3121)
WAHA_BASE_URL=http://waha:3000

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_PRIMARY_MODEL=google/gemini-flash-2.5
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Telegram Admin Notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# App
APP_ENV=development
APP_SECRET_KEY=changeme-secret-key
